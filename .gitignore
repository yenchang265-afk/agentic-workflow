.DS_Store
node_modules/
.env
.env.*
*.log

# Local project config — may hold an ADO PAT (ado.pat); never commit it.
.agentic-workflow.json

# Ephemeral loop-state snapshots + stage marker (durable run logs are the *.md files beside them)
docs/tasks/runs/*.state.json
docs/tasks/runs/.stage.json
docs/tasks/runs/.watch-lease/

# Build output (built by npm workspace `build` scripts / plugins/claude/install.sh)
packages/core/dist/
plugins/claude/mcp-server/dist/

# Codegraph MCP local index (machine-local, not committed)
.codegraph/

# Hub build output (bundled locally by packages/hub/scripts/build-web.mjs)
packages/hub/dist/

# Per-editor rule/skill mirrors sprayed by the code-review-graph installer.
# All duplicate the same MCP blurb into whichever AI editors it detects; this
# repo's real guidance lives in AGENTS.md (CLAUDE.md symlinks to it).
.cursorrules
.windsurfrules
CODEBUDDY.md
GEMINI.md
QODER.md
.codebuddy/
.gemini/
.kiro/
.qoder/
.github/code-review-graph.instruction.md

# Machine-local MCP wiring the same installer writes at the repo root — holds
# absolute paths to a local pipx venv, so it is never portable. Root-anchored:
# plugins/claude/.mcp.json is a real tracked file and must stay committed.
/.mcp.json
/opencode.jsonc
