.DS_Store
node_modules/
.env
.env.*
*.log

# Local project config — may hold an ADO PAT (ado.pat); never commit it.
.agentic-loop.json

# Ephemeral loop-state snapshots + stage marker (durable run logs are the *.md files beside them)
docs/tasks/runs/*.state.json
docs/tasks/runs/.stage.json
docs/tasks/runs/.watch-lease/

# Build output (built by npm workspace `build` scripts / plugins/claude/install.sh)
packages/core/dist/
plugins/claude/mcp-server/dist/

# Codegraph MCP local index (machine-local, not committed)
.codegraph/

# Hub build output (bundled locally by packages/hub/scripts/build-web.mjs)
packages/hub/dist/
