{
  "kind": "engineering",
  "version": 1,
  "description": "The engineering workflow: PLAN (park at the human plan gate) then BUILD → VERIFY → REVIEW over the docs/tasks backlog.",
  "workSource": {
    "type": "backlog",
    "statuses": ["draft", "queued", "plan-review", "in-progress", "in-review", "completed", "abandoned"],
    "pools": [
      { "status": "in-progress", "entryStage": "build", "claimPredicate": "engineering.isClaimable" },
      { "status": "queued", "entryStage": "plan" }
    ]
  },
  "stages": [
    {
      "name": "plan",
      "kind": "work",
      "command": "plan-task",
      "agent": "loop-plan-author",
      "prompt": "stages/plan.md",
      "isolation": "none"
    },
    {
      "name": "build",
      "kind": "work",
      "command": "build",
      "agent": "loop-build",
      "prompt": "stages/build.md",
      "isolation": "worktree"
    },
    {
      "name": "verify",
      "kind": "check",
      "command": "verify",
      "agent": "loop-verify",
      "prompt": "stages/verify.md",
      "isolation": "worktree",
      "bashAllowlist": [
        "git status*", "git diff*", "git log*", "git show*",
        "git -C * status*", "git -C * diff*", "git -C * log*", "git -C * show*",
        "ls*", "cat *", "head *", "tail *", "grep *", "find *", "wc *",
        "npm test*", "npm run *", "pnpm test*", "pnpm run *", "yarn test*", "yarn run *",
        "bun test*", "node --test*", "npx tsc*", "npx vitest*", "npx jest*", "npx eslint*",
        "pytest*", "go test*", "cargo test*", "make test*", "make check*",
        "cd * && npm test*", "cd * && npm run *", "cd * && pnpm test*", "cd * && pnpm run *",
        "cd * && yarn test*", "cd * && yarn run *", "cd * && bun test*", "cd * && node --test*",
        "cd * && npx tsc*", "cd * && npx vitest*", "cd * && npx jest*", "cd * && npx eslint*",
        "cd * && pytest*", "cd * && go test*", "cd * && cargo test*", "cd * && make test*", "cd * && make check*"
      ]
    },
    {
      "name": "review",
      "kind": "check",
      "command": "review",
      "agent": "loop-review",
      "prompt": "stages/review.md",
      "isolation": "worktree",
      "bashAllowlist": [
        "git status*", "git diff*", "git log*", "git show*", "git blame*",
        "git -C * status*", "git -C * diff*", "git -C * log*", "git -C * show*", "git -C * blame*",
        "ls*", "cat *", "head *", "tail *", "grep *", "find *", "wc *"
      ]
    }
  ],
  "transitions": {
    "plan": {
      "onDone": {
        "kind": "park",
        "toStatus": "plan-review",
        "message": "Plan written — parked in plan-review/ for human review. Approve with /agent-loop-task approve-plan."
      }
    },
    "build": {
      "onDone": { "kind": "fire", "stage": "verify" }
    },
    "verify": {
      "onPass": { "kind": "fire", "stage": "review" },
      "onFail": {
        "kind": "fire",
        "stage": "build",
        "countIteration": true,
        "dropArtifacts": ["review"],
        "capMessage": "✗ Loop stopped — verify failed after {maxIterations} iterations. If the plan itself is wrong, send it back to the PLAN stage with /agent-loop-task replan <id>."
      },
      "onError": {
        "kind": "stop",
        "message": "✗ Loop stopped — verify could not run (environment/infrastructure error). Fix the environment, then /agent-loop recover the task."
      }
    },
    "review": {
      "onPass": {
        "kind": "done",
        "toStatus": "in-review",
        "message": "✓ Loop done — review passed. Ship it yourself."
      },
      "onFail": {
        "kind": "fire",
        "stage": "build",
        "countIteration": true,
        "dropArtifacts": ["verify"],
        "capMessage": "✗ Loop stopped — review failed after {maxIterations} iterations. If the plan itself is wrong, send it back to the PLAN stage with /agent-loop-task replan <id>."
      },
      "onError": {
        "kind": "stop",
        "message": "✗ Loop stopped — review could not run (environment/infrastructure error). Fix the environment, then /agent-loop recover the task."
      }
    }
  },
  "hooks": {
    "compose": {},
    "validateBeforeTransition": { "plan": "engineering.planLandedOnDisk" }
  }
}
