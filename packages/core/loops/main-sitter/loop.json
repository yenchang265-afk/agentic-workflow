{
  "kind": "main-sitter",
  "version": 1,
  "description": "Sits on the default branch's CI: when it goes red, diagnoses the failure on that exact head (bisecting when needed), writes a verified forward fix or revert, and opens a draft remedy PR — commenting once on the culprit PR. Never pushes the watched branch; merging stays a human call.",
  "workSource": {
    "type": "ci-runs",
    "workflows": []
  },
  "maxIterations": 2,
  "stages": [
    {
      "name": "diagnose",
      "kind": "check",
      "command": "main-diagnose",
      "agent": "loop-main-diagnose",
      "prompt": "stages/diagnose.md",
      "isolation": "worktree",
      "bashAllowlist": [
        "git status*",
        "git diff*",
        "git log*",
        "git show*",
        "git bisect*",
        "git -C * status*",
        "git -C * diff*",
        "git -C * log*",
        "git -C * show*",
        "git -C * bisect*",
        "ls*",
        "cat *",
        "head *",
        "tail *",
        "grep *",
        "find *",
        "wc *",
        "npm ci*",
        "npm install*",
        "npm test*",
        "npm run *",
        "pnpm test*",
        "pnpm run *",
        "yarn test*",
        "yarn run *",
        "bun test*",
        "node --test*",
        "npx tsc*",
        "npx vitest*",
        "npx jest*",
        "npx eslint*",
        "pytest*",
        "go test*",
        "cargo test*",
        "make test*",
        "make check*",
        "cd * && npm ci*",
        "cd * && npm install*",
        "cd * && npm test*",
        "cd * && npm run *",
        "cd * && pnpm test*",
        "cd * && pnpm run *",
        "cd * && yarn test*",
        "cd * && yarn run *",
        "cd * && bun test*",
        "cd * && node --test*",
        "cd * && npx tsc*",
        "cd * && npx vitest*",
        "cd * && npx jest*",
        "cd * && npx eslint*",
        "cd * && pytest*",
        "cd * && go test*",
        "cd * && cargo test*",
        "cd * && make test*",
        "cd * && make check*",
        "cd * && git bisect*"
      ],
      "platformAllowlist": {
        "github": [
          "gh run view*",
          "gh run list*",
          "gh pr list*",
          "gh pr view*"
        ],
        "ado": [
          "curl -sS -u :* https://dev.azure.com/*",
          "curl -sS -u :* https://*.visualstudio.com/*"
        ]
      }
    },
    {
      "name": "remedy",
      "kind": "work",
      "command": "main-remedy",
      "agent": "loop-main-remedy",
      "prompt": "stages/remedy.md",
      "isolation": "worktree"
    },
    {
      "name": "verify",
      "kind": "check",
      "command": "verify",
      "agent": "loop-verify",
      "prompt": "stages/verify.md",
      "isolation": "worktree",
      "bashAllowlist": [
        "git status*",
        "git diff*",
        "git log*",
        "git show*",
        "git -C * status*",
        "git -C * diff*",
        "git -C * log*",
        "git -C * show*",
        "ls*",
        "cat *",
        "head *",
        "tail *",
        "grep *",
        "find *",
        "wc *",
        "npm test*",
        "npm run *",
        "pnpm test*",
        "pnpm run *",
        "yarn test*",
        "yarn run *",
        "bun test*",
        "node --test*",
        "npx tsc*",
        "npx vitest*",
        "npx jest*",
        "npx eslint*",
        "pytest*",
        "go test*",
        "cargo test*",
        "make test*",
        "make check*",
        "npm ci*",
        "npm install*",
        "npm audit*",
        "npm ls*",
        "npm outdated*",
        "osv-scanner *",
        "mvn test*",
        "mvn verify*",
        "mvn dependency:tree*",
        "./mvnw test*",
        "./mvnw verify*",
        "./mvnw dependency:tree*",
        "gradle test*",
        "gradle check*",
        "gradle build*",
        "gradle dependencyInsight*",
        "./gradlew test*",
        "./gradlew check*",
        "./gradlew build*",
        "./gradlew dependencyInsight*",
        "cd * && npm test*",
        "cd * && npm run *",
        "cd * && pnpm test*",
        "cd * && pnpm run *",
        "cd * && yarn test*",
        "cd * && yarn run *",
        "cd * && bun test*",
        "cd * && node --test*",
        "cd * && npx tsc*",
        "cd * && npx vitest*",
        "cd * && npx jest*",
        "cd * && npx eslint*",
        "cd * && pytest*",
        "cd * && go test*",
        "cd * && cargo test*",
        "cd * && make test*",
        "cd * && make check*",
        "cd * && npm ci*",
        "cd * && npm install*",
        "cd * && npm audit*",
        "cd * && npm ls*",
        "cd * && osv-scanner *",
        "cd * && mvn test*",
        "cd * && mvn verify*",
        "cd * && mvn dependency:tree*",
        "cd * && ./mvnw test*",
        "cd * && ./mvnw verify*",
        "cd * && ./mvnw dependency:tree*",
        "cd * && gradle test*",
        "cd * && gradle check*",
        "cd * && gradle build*",
        "cd * && gradle dependencyInsight*",
        "cd * && ./gradlew test*",
        "cd * && ./gradlew check*",
        "cd * && ./gradlew build*",
        "cd * && ./gradlew dependencyInsight*"
      ]
    },
    {
      "name": "publish",
      "kind": "work",
      "command": "main-publish",
      "agent": "loop-main-publish",
      "prompt": "stages/publish.md",
      "isolation": "worktree",
      "bashAllowlist": [
        "git push origin main-sitter/*",
        "git -C * push origin main-sitter/*",
        "git status*",
        "git diff*",
        "git log*",
        "git show*",
        "git -C * status*",
        "git -C * diff*",
        "git -C * log*",
        "git -C * show*",
        "ls*",
        "cat *",
        "head *",
        "tail *",
        "grep *",
        "wc *"
      ],
      "platformAllowlist": {
        "github": [
          "gh pr create *",
          "gh pr view*",
          "gh pr list*",
          "gh pr comment *"
        ],
        "ado": [
          "curl -sS -u :* https://dev.azure.com/*",
          "curl -sS -u :* https://*.visualstudio.com/*"
        ]
      }
    }
  ],
  "transitions": {
    "diagnose": {
      "onPass": {
        "kind": "fire",
        "stage": "remedy"
      },
      "onFail": {
        "kind": "done",
        "message": "✓ Main sitter done — the failure is a flake or the branch already recovered; no remedy needed."
      },
      "onError": {
        "kind": "stop",
        "message": "✗ Main sitter stopped — diagnose could not reproduce or inspect the failure (environment error). Fix the environment and let the next poll retry."
      }
    },
    "remedy": {
      "onDone": {
        "kind": "fire",
        "stage": "verify"
      }
    },
    "verify": {
      "onPass": {
        "kind": "fire",
        "stage": "publish"
      },
      "onFail": {
        "kind": "fire",
        "stage": "remedy",
        "countIteration": true,
        "dropArtifacts": [],
        "capMessage": "✗ Main sitter stopped — verify failed after {maxIterations} iterations; prefer the revert path. The attempt is recorded; this head parks until a new push replaces it."
      },
      "onError": {
        "kind": "stop",
        "message": "✗ Main sitter stopped — verify could not run (environment/infrastructure error)."
      }
    },
    "publish": {
      "onDone": {
        "kind": "done",
        "message": "✓ Main sitter done — pushed the remedy and opened a draft PR. The watched branch was never touched; merging stays a human call."
      }
    }
  },
  "hooks": {
    "compose": {},
    "validateBeforeTransition": {}
  }
}
